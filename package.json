{
    "name": "stacker-arcade",
    "version": "1.0.0",
    "description": "Stacker Arcade Electron Build",
    "main": "dist/main.cjs",
    "author": "MarketingPipeline",
    "scripts": {
        "start": "electron .",
        "build:browser": "esbuild main.js --bundle --format=esm --outfile=dist/main.js",
        "build:exe": "esbuild main.js --bundle --platform=node --format=cjs --outfile=dist/main.js && electron-builder"
    },
    "devDependencies": {
        "electron": "22.3.27",
        "electron-builder": "^24.0.0"
    },
    "build": {
        "npmRebuild": false,
        "appId": "com.stacker.arcade",
        "productName": "Stacker",
        "compression": "maximum",
        "extraFiles": [],
        "win": {
            "target": [
                {
                    "target": "portable",
                    "arch": [
                        "ia32"
                    ]
                }
            ]
        }
    }
}
