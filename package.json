{
    "name": "stacker-arcade",
    "version": "1.0.0",
    "description": "Stacker Arcade Electron Build",
    "main": "src/electron.js",
    "author": "MarketingPipeline",
    "scripts": {
        "build:library": "esbuild ./src/game.js --bundle --format=esm --outfile=dist/game.js",
        "build:ghpages": "webpack --config ./website/webpack.config.js",
        "build:main": "esbuild ./src/electron.js --bundle --platform=node --format=cjs --outfile=dist/main.js --external:electron",
        "build:exe": "webpack --config ./src/webpack.config.js  && neu build"
    },
    "devDependencies": {
        "electron": "22.3.27",
        "electron-builder": "^24.0.0",
        "webpack": "^5.93.0",
        "webpack-cli": "^5.1.4",
        "webpack-dev-server": "^5.0.4",
        "autoprefixer": "^10.4.27",
        "css-loader": "^7.1.4",
        "html-loader": "^5.1.0",
        "html-webpack-plugin": "^5.6.6",
        "mini-css-extract-plugin": "^2.10.2",
        "postcss": "^8.5.0",
        "postcss-loader": "^8.1.1",
        "style-loader": "^4.0.0",
        "tailwindcss": "^4.2.2",
        "html-inline-css-webpack-plugin": "^1.11.1",
        "html-inline-script-webpack-plugin": "^3.2.1",
        "esbuild": "^0.19.0"
    },
    "build": {
        "npmRebuild": false,
        "appId": "com.stacker.arcade",
        "productName": "Stacker",
        "compression": "maximum",
        "extraFiles": [],
        "asar": true,
        "files": [
            "dist/game.html",
            "src/electron.js",
            "src/settings.js",
            "preload.js",
            "package.json"
        ],    
        "win": {
            "target": [
                {
                    "target": "portable",
                    "arch": [
                        "ia32"
                    ]
                }
            ],
            "requestedExecutionLevel": "asInvoker"
        },
        "linux": {
        "target": ["AppImage"],
        "category": "Game"
        }
    }
}
