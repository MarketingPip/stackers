{
  "name": "stacker-arcade",
  "version": "1.0.0",
  "description": "Stacker Arcade Electron Build",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.stacker.arcade",
    "productName": "Stacker",
    "files": [
      "index.html",
      "main.js"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
