{
  "applicationId": "js.arcade.game",
  "version": "1.0.0",
  "defaultMode": "window",
  "documentRoot": "/dist/",
  "url": "/game.html",
  "enableServer": true,
  "enableNativeCalls": true,
  "modes": {
    "window": {
      "title": "Arcade Game",
      "width": 900,
      "height": 1000,
      "minWidth": 400,
      "minHeight": 400,
      "fullScreen": false,
      "alwaysOnTop": false,
      "enableInspector": false,
      "borderless": false,
      "maximize": false,
      "hidden": false,
      "resizable": true,
      "exitProcessOnClose": true
    }
  },
  "launcherConfig": {
    "singleInstance": true
  }
}
