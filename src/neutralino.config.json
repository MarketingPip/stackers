{
  "applicationId": "js.arcade.game",
  "version": "1.0.0",
  "defaultMode": "window",
  "documentRoot": "../dist/",
  "url": "/game.html",
  "enableServer": true,
  "enableNativeCalls": true,
  "modes": {
    "window": {
      "title": "Arcade Game",
      "width": 900,
      "height": 1000,
      "fullScreen": false,
      "alwaysOnTop": false,
      "enableInspector": false,
      "borderless": false,
      "maximize": false,
      "exitProcessOnClose": true
    }
  },
  "cli": {
    "binaryName": "arcade-game",
    "resourcesPath": "../dist/",
    "clientLibrary": "../dist/neutralino.js",
    "binaryVersion": "4.14.1"
  },
  "launcherConfig": {
    "singleInstance": true
  }
}
