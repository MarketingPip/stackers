{
  "name": "stacker-arcade",
  "version": "1.0.0",
  "description": "Stacker Arcade Electron Build",
  "main": "dist/main.js",
  "scripts": {
    "start": "electron .",
    "build:renderer": "esbuild src/index.js --bundle --minify --outfile=dist/app.js",
    "build:main": "esbuild src/main.js --bundle --platform=node --outfile=dist/main.js",
    "build": "npm run build:main && npm run build:renderer",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "electron": "22.3.27",
    "electron-builder": "^24.0.0",
    "esbuild": "^0.19.0"
  },
  "build": {
    "npmRebuild": false,
    "asar": true,
    "compression": "maximum",
    "appId": "com.stacker.arcade",
    "productName": "Stacker",
    "electronDownload": {
      "mirror": "https://github.com/electron/electron/releases/download/"
    },
    "files": [
      "!**/*.map",
      "!**/test/**",
      "!**/*.md",
      "!node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "dist/**/*",
      "index.html",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["ia32", "x64"]
        }
      ]
    }
  }
}
