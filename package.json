{
    "name": "stacker-arcade",
    "version": "1.0.0",
    "description": "Stacker Arcade Electron Build",
    "main": "src/electron.js",
    "author": "MarketingPipeline",
    "scripts": {
        "start": "electron .",
        "build:browser": "esbuild main.js --bundle --format=esm --outfile=dist/main.js",
        "build:ghpages": "webpack --config ./website/webpack.config.js",
        "deploy": "npm run build:ghpages && gh-pages -d dist",
        "build:exe": "webpack --config ./src/webpack.config.js  && electron-builder"
    },
    "devDependencies": {
        "electron": "22.3.27",
        "electron-builder": "^24.0.0",
        "webpack": "^5.93.0",
        "webpack-cli": "^5.1.4"
    },
    "build": {
        "npmRebuild": false,
        "appId": "com.stacker.arcade",
        "productName": "Stacker",
        "compression": "maximum",
        "extraFiles": [],
        "win": {
            "target": [
                {
                    "target": "portable",
                    "arch": [
                        "ia32"
                    ]
                }
            ]
        }
    }
}
