{
  "name": "stacker-arcade",
  "version": "1.0.0",
  "description": "Stacker Arcade Electron Build",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "22.3.27",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "npmRebuild": false,
    "compression": "maximum",
    "appId": "com.stacker.arcade",
    "extraResources": [],
    "productName": "Stacker",
    "asar": true,
    "compression": "maximum",
    "electronDownload": {
      "mirror": "https://github.com/electron/electron/releases/download/"
    },
    "files": [
      "!**/*.map",
      "!**/test/**",
      "!**/*.md",
      "!node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "dist/**/*",
      "index.html",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["ia32"]
        }
      ]
    }
  }
}
