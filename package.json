{
  "name": "stacker-arcade",
  "version": "1.0.0",
  "description": "Stacker Arcade Electron Build",
  "main": "dist/main.js",
  "scripts": {
    "start": "electron .",
    "build:main": "esbuild main.js --bundle --platform=node --outfile=dist/main.js",
    "build": "npm run build:main",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "electron": "22.3.27",
    "electron-builder": "^24.0.0",
    "esbuild": "^0.19.0"
  },
  "build": {
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [],
    "compression": "maximum",
    "appId": "com.stacker.arcade",
    "productName": "Stacker",
    "files": [
      "dist/**/*",
      "index.html",
      "preload.js",
      "package.json",
      "!**/node_modules/*",
      "!dist/win-unpacked/**/*",
      "!dist/*.exe"
    ],
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "differentialPackage": true,
      "compress": "lzma" 
    },
    "extraFiles": [],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["ia32"]
        }
      ]
    }
  }
}
